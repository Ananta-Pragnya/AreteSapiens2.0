# Copy this file to .env.local and fill in your key.
OPENAI_API_KEY=

# Optional model overrides (defaults shown). Change these if you have access
# to newer/cheaper vision, text, code-gen, or transcription models.
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_CODEGEN_MODEL=gpt-4o
OPENAI_WRITER_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Cross-link to the Arete Sapiens suite (Vaakil, bills, warranties, groceries).
# Vaakil is exposed by the Claim Guardian server at /vaakil. This internal
# origin is only used by the server-side proxy, so all browser access stays
# on http://localhost:3000.
ARETE_SAPIENS_ORIGIN=http://127.0.0.1:8080
